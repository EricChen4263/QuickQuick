{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickQuick",
  "version": "0.1.1",
  "identifier": "com.quickquick.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "QuickQuick",
        "width": 960,
        "height": 640,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 18, "y": 12 },
        "hiddenTitle": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI1Q0REMEYyQUNGMDNGQkMKUldTOFAvQ3M4dEROSmRoOVVuMWt5bkkxTWdKbVhjaWxuS2tqdWhYRkw3RmQrSjY1VGN5bjNKMWUK",
      "endpoints": [
        "https://github.com/EricChen4263/QuickQuick/releases/latest/download/latest.json"
      ]
    }
  }
}
