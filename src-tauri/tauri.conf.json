{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickQuick",
  "version": "0.0.1",
  "identifier": "com.quickquick.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QuickQuick",
        "width": 400,
        "height": 600,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXkKUldTUGhkZFBPZUZDQXZmTVVaZFhUOHZZN3RUNkVOQlhSZFdNWFhnYVBGRlZIczlvRFhBQVBhOUQK",
      "endpoints": [
        "https://placeholder.example.com/quickquick/{{target}}/{{arch}}/{{current_version}}"
      ]
    },
    "autostart": {
      "args": false,
      "macos-auto-start-at-login-enabled": true
    }
  }
}
