{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickQuick",
  "version": "0.1.0",
  "identifier": "com.quickquick.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "QuickQuick",
        "width": 960,
        "height": 640,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "ZFc1MGNuVnpkR1ZrSUdOdmJXMWxiblE2SUcxcGJtbHphV2R1SUhCMVlteHBZeUJyWlhrNklESTFRMFJFTUVZeVFVTkdNRE5HUWtNS1VsZFRPRkF2UTNNNGRFUk9TbVJvT1ZWdU1XdDVia2t4VFdkS2JWaGphV3h1UzJ0cWRXaFlSa3czUm1RclNqWTFWR041YmpOS01XVUs=",
      "endpoints": [
        "https://github.com/EricChen4263/QuickQuick/releases/latest/download/latest.json"
      ]
    }
  }
}
